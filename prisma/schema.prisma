// ShareO — Prisma Schema v0.1 (MVP H1)
// Gerado em: 2026-05-22
// Revisar com o Arquiteto antes de aplicar a staging

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum UserType {
  PF // Pessoa Física — usa CPF
  PJ // Pessoa Jurídica — usa CNPJ
}

enum UserRole {
  USER
  ADMIN
}

enum ItemCondition {
  NEW // Novo
  EXCELLENT // Excelente
  GOOD // Bom
  FAIR // Regular
}

enum BookingStatus {
  PENDING // Aguardando resposta do locador
  CONFIRMED // Locador aceitou
  ACTIVE // Aluguel em andamento
  RETURNED // Item devolvido, aguardando avaliação
  COMPLETED // Concluído (avaliações feitas ou 7 dias após devolução)
  CANCELLED // Cancelado por qualquer parte
  DISPUTED // Disputa aberta
}

enum PaymentStatus {
  PENDING // Aguardando pagamento
  PAID // Pago com sucesso
  REFUNDED // Estornado
  FAILED // Falhou
}

enum ReviewType {
  ITEM // Locatário avalia o item
  BORROWER // Locador avalia o locatário
  OWNER // Locatário avalia o locador
}

enum NotificationType {
  BOOKING_REQUEST
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_RETURNED
  BOOKING_AUTO_CANCELLED
  NEW_MESSAGE
  NEW_REVIEW
  ITEM_APPROVED
  ITEM_REJECTED
  REFERRAL_CREDIT
  CONTRACT_PENDING
  CHECKIN_DONE
  CHECKOUT_DONE
  LATE_FEE_APPLIED
  ID_VERIFIED
  ID_REJECTED
  RETURN_REMINDER // P2-59 — lembrete manual de devolução enviado pelo proprietário
}

enum CheckPhase {
  CHECKIN
  CHECKOUT
}

enum IdVerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

// ─── Models ──────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  name          String
  phone         String?
  userType      UserType  @default(PF)
  role          UserRole  @default(USER)

  // Documentos — armazenados criptografados (ver ADR-004)
  // Nunca expor em respostas de API sem mascaramento
  cpfHash       String? @unique // bcrypt hash para verificação de unicidade
  cpfEncrypted  String? // AES-256-GCM para exibição mascarada
  cnpjHash      String? @unique
  cnpjEncrypted String?

  // Perfil
  slug      String? @unique // URL da vitrine: /loja/[slug] — gerado no cadastro, editável
  avatarUrl String?
  bio       String? @db.Text

  // Localização (base do usuário — para geo-search de proximidade)
  city         String?
  state        String? @db.Char(2)
  neighborhood String?
  // PostGIS: requer extensão "postgis" ativa no Supabase
  // lat/lng armazenados separadamente para queries sem PostGIS no dev
  latitude     Float?
  longitude    Float?

  // Programa de indicação
  referralCode    String?          @unique // código único gerado no cadastro (ex.: "JOAO-X4K2")
  referredById    String? // quem indicou este usuário
  referredBy      User?            @relation("Referrals", fields: [referredById], references: [id])
  referrals       User[]           @relation("Referrals")
  referralCredits ReferralCredit[]

  isVerified Boolean @default(false)
  isActive   Boolean @default(true)

  // P3-70: pontos de reputação (+10 por avaliação enviada)
  reputationPoints Int @default(0)

  // Verificação de identidade
  idVerificationStatus IdVerificationStatus @default(UNVERIFIED)
  idDocumentUrl        String?
  idSelfieUrl          String?
  idSubmittedAt        DateTime?
  idVerifiedAt         DateTime?
  idRejectionReason    String?

  // LGPD — consentimento explícito no cadastro
  consentAt      DateTime?
  consentIp      String?
  consentVersion String? // versão da política aceita (ex.: "v1.0")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // soft delete — nunca delete fisicamente

  // Relações
  items              Item[]
  bookingsAsBorrower Booking[]                 @relation("BorrowerBookings")
  bookingsAsOwner    Booking[]                 @relation("OwnerBookings")
  reviewsGiven       Review[]                  @relation("ReviewsGiven")
  reviewsReceived    Review[]                  @relation("ReviewsReceived")
  favorites          Favorite[]
  messages           Message[]
  conversations      ConversationParticipant[]
  notifications      Notification[]
  adminLogs          AdminLog[]
  outboundWebhooks   OutboundWebhook[]
  // NextAuth.js — @auth/prisma-adapter
  accounts           Account[]
  sessions           Session[]

  @@index([email])
  @@index([latitude, longitude])
  @@map("users")
}

model Category {
  id        String     @id @default(cuid())
  slug      String     @unique // ex.: "ferramentas", "eletronicos"
  name      String
  icon      String? // nome do SVG em /icones/
  parentId  String?
  parent    Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children  Category[] @relation("SubCategories")
  items     Item[]
  createdAt DateTime   @default(now())

  @@map("categories")
}

model Item {
  id         String   @id @default(cuid())
  ownerId    String
  owner      User     @relation(fields: [ownerId], references: [id])
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  title       String
  slug        String?       @unique // ex.: "furadeira-dewalt-em-sao-paulo-sp" — SEO URL
  description String        @db.Text
  condition   ItemCondition @default(GOOD)

  // Preços — em centavos (evita float rounding issues)
  pricePerDay          Int // obrigatório
  pricePerWeek         Int?
  pricePerMonth        Int?
  depositAmount        Int? // caução
  rules                String? @db.Text // P2-51 — regras do anunciante (ex.: "Não use na chuva")
  estimatedRetailPrice Int? // valor estimado de compra (para calculadora alugar vs comprar)

  // Localização do item
  address      String?
  city         String
  state        String  @db.Char(2)
  neighborhood String?
  latitude     Float
  longitude    Float
  // Coluna geográfica PostGIS (Unsupported até Prisma nativo suportar)
  // geom        Unsupported("geometry(Point, 4326)")?

  // Voltagem — para itens elétricos/eletrônicos
  voltage String? // "110V" | "220V" | "Bivolt" — null = não se aplica

  // Requisitos para reserva
  requireIdVerification Boolean @default(false) // locatário precisa ter identidade verificada
  requirePhone          Boolean @default(false) // locatário precisa ter telefone cadastrado

  // Status
  isActive     Boolean   @default(true)
  isApproved   Boolean   @default(true) // true = publicação direta (moderação reativa no MVP)
  approvedAt   DateTime?
  approvedById String?

  viewCount Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relações
  images    ItemImage[]
  bookings  Booking[]
  reviews   Review[]
  favorites Favorite[]

  @@index([ownerId])
  @@index([categoryId])
  @@index([latitude, longitude])
  @@index([isActive, isApproved, deletedAt])
  @@index([slug])
  @@map("items")
}

model ItemImage {
  id        String   @id @default(cuid())
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([itemId])
  @@map("item_images")
}

model Booking {
  id         String @id @default(cuid())
  itemId     String
  item       Item   @relation(fields: [itemId], references: [id])
  borrowerId String
  borrower   User   @relation("BorrowerBookings", fields: [borrowerId], references: [id])
  ownerId    String
  owner      User   @relation("OwnerBookings", fields: [ownerId], references: [id])

  status BookingStatus @default(PENDING)

  startDate DateTime
  endDate   DateTime
  totalDays Int

  // Snapshot de preço no momento da solicitação (protege contra mudança de preço)
  dailyPrice    Int
  totalPrice    Int
  depositAmount Int?

  borrowerNote String? @db.Text
  ownerNote    String? @db.Text

  // Pagamento via Stripe
  paymentStatus         PaymentStatus @default(PENDING)
  stripeSessionId       String?       @unique // Stripe Checkout Session ID
  stripePaymentIntentId String?
  paidAt                DateTime?

  cancelledAt   DateTime?
  cancelledById String?
  cancelReason  String?

  // Política de cancelamento — calculado no momento do cancelamento
  refundAmount  Int? // valor a reembolsar em centavos (null = não cancelado)
  refundPercent Int? // 100 | 70 | 50 — percentual aplicado pela política

  // Resposta do proprietário (para cálculo do badge de responsividade)
  respondedAt DateTime? // quando o dono aceitou ou recusou (primeira ação sobre PENDING)

  // Devolução e taxa de atraso
  returnedAt    DateTime? // data real de devolução (pode ser após endDate)
  lateFeeAmount Int? // cents — calculado se returnedAt > endDate

  // Contrato digital
  contractSignedAt DateTime?

  // P1-27 — Extensão de prazo
  extensionRequestedEndDate DateTime? // nova data de devolução solicitada pelo locatário
  extensionStatus           String? // "PENDING" | "APPROVED" | "REJECTED"
  extensionRequestedAt      DateTime? // quando a solicitação foi feita
  extensionRespondedAt      DateTime? // quando o proprietário respondeu

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // soft delete — LGPD obrigatório em dados transacionais

  // Relações
  reviews            Review[]
  conversation       Conversation?
  photos             BookingPhoto[]
  contractAcceptance ContractAcceptance?

  @@index([borrowerId])
  @@index([ownerId])
  @@index([itemId])
  @@index([status])
  @@index([deletedAt])
  @@index([itemId, status, startDate, endDate])
  @@map("bookings")
}

model Review {
  id         String  @id @default(cuid())
  bookingId  String
  booking    Booking @relation(fields: [bookingId], references: [id])
  reviewerId String
  reviewer   User    @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  revieweeId String
  reviewee   User    @relation("ReviewsReceived", fields: [revieweeId], references: [id])
  itemId     String?
  item       Item?   @relation(fields: [itemId], references: [id])

  reviewType ReviewType
  rating     Int     // 1–5 overall
  comment    String? @db.Text

  // P3-68: emoji de satisfação (😠1 😕2 😐3 😊4 😍5)
  sentiment       Int?
  // P3-67: critérios por tipo de avaliação
  itemAsDescribed Int? // ITEM: item como descrito
  punctuality     Int? // OWNER/BORROWER: pontualidade
  communication   Int? // OWNER/BORROWER: comunicação
  conservation    Int? // ITEM/BORROWER: conservação/cuidado
  // P3-69: foto do item em uso
  photoUrl        String?

  createdAt DateTime @default(now())

  // Um revisor só avalia uma vez por booking por tipo
  @@unique([bookingId, reviewerId, reviewType])
  @@index([revieweeId])
  @@index([itemId])
  @@map("reviews")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, itemId])
  @@map("favorites")
}

model Conversation {
  id            String    @id @default(cuid())
  bookingId     String?   @unique
  booking       Booking?  @relation(fields: [bookingId], references: [id])
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())

  messages     Message[]
  participants ConversationParticipant[]

  @@map("conversations")
}

model ConversationParticipant {
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  lastReadAt     DateTime?

  @@id([conversationId, userId])
  @@index([userId])
  @@map("conversation_participants")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id])
  content        String       @db.Text
  readAt         DateTime?
  createdAt      DateTime     @default(now())
  deletedAt      DateTime? // soft delete — LGPD obrigatório em mensagens privadas

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("messages")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  data      Json? // dados extras (ex.: bookingId, itemId)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt])
  @@map("notifications")
}

// ─── NextAuth.js — requerido pelo @auth/prisma-adapter ───────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────────────────────────────────────

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@map("password_reset_tokens")
}

// ─────────────────────────────────────────────────────────────────────────────

// Webhooks de saída para integração PJ com ERPs e sistemas externos
model OutboundWebhook {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  url      String // endpoint que receberá os eventos
  events   String[] // ex.: ["booking.confirmed", "booking.paid"]
  secret   String // HMAC-SHA256 secret (mostrado apenas no momento da criação)
  isActive Boolean  @default(true)

  // Auditoria das últimas entregas
  lastFiredAt    DateTime?
  lastStatusCode Int?
  failureCount   Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("outbound_webhooks")
}

// ─────────────────────────────────────────────────────────────────────────────

// Créditos do programa de indicação
model ReferralCredit {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  amountCents Int // valor em centavos (ex.: 1500 = R$15)
  reason      String // ex.: "Indicação aceita — João Silva", "Primeiro aluguel concluído"
  usedAt      DateTime? // null = disponível, não null = já usado
  expiresAt   DateTime? // validade opcional

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("referral_credits")
}

model AdminLog {
  id         String   @id @default(cuid())
  adminId    String
  admin      User     @relation(fields: [adminId], references: [id])
  action     String // ex.: "APPROVE_ITEM", "BAN_USER", "RESOLVE_DISPUTE"
  entityType String // ex.: "Item", "User", "Booking"
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([adminId])
  @@index([entityType, entityId])
  @@map("admin_logs")
}

// ─── Fotos de check-in / check-out ───────────────────────────────────────────

model BookingPhoto {
  id         String     @id @default(cuid())
  bookingId  String
  booking    Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  url        String
  phase      CheckPhase // CHECKIN | CHECKOUT
  uploadedBy String // userId de quem fez o upload

  createdAt DateTime @default(now())

  @@index([bookingId])
  @@map("booking_photos")
}

// ─── Contrato digital ─────────────────────────────────────────────────────────

model ContractAcceptance {
  id        String  @id @default(cuid())
  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  acceptedAt DateTime @default(now())
  ipAddress  String?
  userAgent  String?

  @@map("contract_acceptances")
}
