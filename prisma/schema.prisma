// ShareO — Prisma Schema v0.1 (MVP H1)
// Gerado em: 2026-05-22
// Revisar com o Arquiteto antes de aplicar a staging

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum UserType {
  PF // Pessoa Física — usa CPF
  PJ // Pessoa Jurídica — usa CNPJ
}

enum UserRole {
  USER
  ADMIN
}

enum AdminRole {
  ADMIN_SUPERADMIN
  ADMIN_FINANCEIRO
  ADMIN_OPERACIONAL
}

enum ItemCondition {
  NEW // Novo
  EXCELLENT // Excelente
  GOOD // Bom
  FAIR // Regular
}

enum ItemStatus {
  DRAFT     // Rascunho — sem fotos; não aparece em listagens públicas
  AVAILABLE // Publicado e disponível para reserva
  PAUSED    // Pausado pelo proprietário
  DELETED   // Soft-delete — fonte de verdade para exclusão lógica
}

enum BookingStatus {
  PENDING // Aguardando resposta do locador
  CONFIRMED // Locador aceitou
  ACTIVE // Aluguel em andamento
  RETURNED // Item devolvido, aguardando avaliação
  COMPLETED // Concluído (avaliações feitas ou 7 dias após devolução)
  CANCELLED // Cancelado por qualquer parte
  DISPUTED // Disputa aberta
}

enum PaymentStatus {
  PENDING // Aguardando pagamento
  PAID // Pago com sucesso
  REFUNDED // Estornado
  FAILED // Falhou
}

enum ReviewType {
  ITEM // Locatário avalia o item
  BORROWER // Locador avalia o locatário
  OWNER // Locatário avalia o locador
}

enum NotificationType {
  BOOKING_REQUEST
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_RETURNED
  BOOKING_AUTO_CANCELLED
  NEW_MESSAGE
  NEW_REVIEW
  ITEM_APPROVED
  ITEM_REJECTED
  REFERRAL_CREDIT
  CONTRACT_PENDING
  CHECKIN_DONE
  CHECKOUT_DONE
  LATE_FEE_APPLIED
  ID_VERIFIED
  ID_REJECTED
  RETURN_REMINDER          // P2-59 — lembrete manual de devolução enviado pelo proprietário
  AMBASSADOR_COMMISSION    // ADR-022 — comissão gerada por locação de indicado
  AMBASSADOR_TIER_UP       // ADR-022 — embaixador subiu de tier
  COUPON_EARNED            // P3-20 — cupom de desconto ganho por avaliar
}

enum CheckPhase {
  CHECKIN
  CHECKOUT
}

enum IdVerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum DepositStatus {
  NONE
  HELD
  RELEASED
  RETAINED
}

enum PixKeyType {
  CPF
  CNPJ
  EMAIL
  PHONE
  RANDOM
}

enum PixAccountStatus {
  PENDING_VERIFICATION
  VERIFIED
  REJECTED
}

enum TransactionType {
  PAYMENT_RECEIVED
  PLATFORM_FEE
  OWNER_PAYOUT
  REFUND
  DISPUTE_HOLD
  AMBASSADOR_COMMISSION // ADR-022 — custo de comissão de embaixador (sai do bolso da plataforma)
}

// ─── Programa de Embaixadores (ADR-022) ──────────────────────────

enum AmbassadorTier {
  BRONZE // 1–10 indicados ativos — 3% da taxa
  SILVER // 11–50 indicados ativos — 5% da taxa
  GOLD   // 51+ indicados ativos — 7% da taxa
}

enum ReferralStatus {
  PENDING // indicado se cadastrou, ainda sem reserva paga
  ACTIVE  // primeira reserva paga concluída — conta no tier
  EXPIRED // sem reserva paga nos últimos 12 meses
}

enum CommissionStatus {
  PENDING   // criada no webhook Stripe (checkout.session.completed)
  APPROVED  // T+7 dias após COMPLETED do booking — janela anti-dispute
  PAID      // pago via PIX/Connect — BLOQUEADO até D4 jurídico
  CANCELLED // booking refunded, cancelled ou dispute lost
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  BLOCKED
}

enum ExportJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum EventQueueStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum FounderWave {
  WAVE_1 // Posições 1–500   — primeiros fundadores
  WAVE_2 // Posições 501–1500
  WAVE_3 // Posições 1501+
}

enum LeadStatus {
  PENDING      // E-mail cadastrado, aguardando convite
  INVITED      // Link de convite enviado
  CONVERTED    // Usuário criou conta via convite
  UNSUBSCRIBED // Pediu exclusão
}

enum SignupSource {
  ORGANIC     // Acesso direto / orgânico
  VIP_LANDING // Formulário "Entrar na Lista"
  REFERRAL    // Indicação de outro usuário
  GOOGLE_ADS
  META_ADS
}

// ─── Models ──────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified       DateTime?
  emailVerifyToken    String?   @unique
  emailTokenExpiresAt DateTime?
  passwordHash  String?
  name          String
  phone         String?
  userType      UserType  @default(PF)
  role          UserRole  @default(USER)
  adminRole     AdminRole? // só presente em usuários com role=ADMIN; define o escopo de permissões

  // Documentos — armazenados criptografados (ver ADR-004)
  // Nunca expor em respostas de API sem mascaramento
  cpfHash       String? @unique // bcrypt hash para verificação de unicidade
  cpfEncrypted  String? // AES-256-GCM para exibição mascarada
  cnpjHash      String? @unique
  cnpjEncrypted String?

  // Perfil
  slug      String? @unique // URL da vitrine: /loja/[slug] — gerado no cadastro, editável
  avatarUrl String?
  bio       String? @db.Text

  // Localização (base do usuário — para geo-search de proximidade)
  cep          String? @db.Char(8)  // somente dígitos, ex.: "59114270"
  street       String?              // logradouro preenchido via ViaCEP
  neighborhood String?
  city         String?
  state        String? @db.Char(2)
  // PostGIS: requer extensão "postgis" ativa no Supabase
  // lat/lng armazenados separadamente para queries sem PostGIS no dev
  latitude     Float?
  longitude    Float?

  // Programa de indicação / Embaixadores (ADR-022)
  // referralCode: slug único do link de indicação (mantido por compatibilidade — ex.: "JOAO-X4K2")
  referralCode    String?          @unique
  referredById    String? // quem indicou este usuário (atribuição direta no User)
  referredBy      User?            @relation("Referrals", fields: [referredById], references: [id])
  referrals       User[]           @relation("Referrals")
  // Perfil de embaixador (opt-in explícito, criado quando o usuário aceita o termo do programa)
  ambassadorProfile     AmbassadorProfile?
  // Arestas do grafo de indicações (ADR-022) — denormalizadas além do referredById para suportar
  // status (PENDING/ACTIVE/EXPIRED) e janela de 12 meses para cálculo de tier
  referralsAsReferrer   Referral[]              @relation("ReferralsAsReferrer")
  referralAsReferred    Referral?               @relation("ReferralAsReferred")
  ambassadorCommissions AmbassadorCommission[]  @relation("AmbassadorCommissions")

  isVerified Boolean @default(false)
  isActive   Boolean @default(true)

  // P3-70: pontos de reputação (+10 por avaliação enviada)
  reputationPoints Int @default(0)

  // Verificação de identidade
  idVerificationStatus IdVerificationStatus @default(UNVERIFIED)
  idDocumentUrl        String?
  idSelfieUrl          String?
  idSubmittedAt        DateTime?
  idVerifiedAt         DateTime?
  idRejectionReason    String?

  // LGPD — consentimento explícito no cadastro
  consentAt      DateTime?
  consentIp      String?
  consentVersion String? // versão da política aceita (ex.: "v1.0")

  // Programa Fundadores (não ativar customFeeRate/searchBoost antes do D4 jurídico)
  isFounder        Boolean     @default(false)
  founderWave      FounderWave?
  founderJoinedAt  DateTime?
  customFeeRate    Int?         // basis points; null → usa taxa global
  searchBoost      Float?       // multiplicador de relevância; null → 1.0
  signupSource     SignupSource @default(ORGANIC)
  signupSourceMeta Json?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // soft delete — nunca delete fisicamente

  // Relações
  items              Item[]
  bookingsAsBorrower Booking[]                 @relation("BorrowerBookings")
  bookingsAsOwner    Booking[]                 @relation("OwnerBookings")
  reviewsGiven       Review[]                  @relation("ReviewsGiven")
  reviewsReceived    Review[]                  @relation("ReviewsReceived")
  favorites          Favorite[]
  messages           Message[]
  conversations      ConversationParticipant[]
  notifications      Notification[]
  adminLogs          AdminLog[]
  exportJobs         ExportJob[]
  outboundWebhooks   OutboundWebhook[]
  // NextAuth.js — @auth/prisma-adapter
  accounts            Account[]
  sessions            Session[]
  ownerPaymentAccount OwnerPaymentAccount?
  founderLead         FounderLead?
  coupons             Coupon[]

  @@index([email])
  @@index([latitude, longitude])
  @@map("users")
}

model Category {
  id        String     @id @default(cuid())
  slug      String     @unique // ex.: "ferramentas", "eletronicos"
  name      String
  icon      String? // nome do SVG em /icones/
  parentId  String?
  parent    Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children  Category[] @relation("SubCategories")
  items     Item[]
  createdAt DateTime   @default(now())

  @@map("categories")
}

model Item {
  id         String   @id @default(cuid())
  ownerId    String
  owner      User     @relation(fields: [ownerId], references: [id])
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  title       String
  slug        String?       @unique // ex.: "furadeira-dewalt-em-sao-paulo-sp" — SEO URL
  description String        @db.Text
  condition   ItemCondition @default(GOOD)

  // Preços — em centavos (evita float rounding issues)
  pricePerDay          Int // obrigatório
  pricePerWeek         Int?
  pricePerMonth        Int?
  depositAmount        Int? // caução
  rules                String? @db.Text // P2-51 — regras do anunciante (ex.: "Não use na chuva")
  estimatedRetailPrice Int? // valor estimado de compra (para calculadora alugar vs comprar)

  // Localização do item
  address      String?
  city         String
  state        String  @db.Char(2)
  neighborhood String?
  latitude     Float
  longitude    Float
  // Coluna geográfica PostGIS (Unsupported até Prisma nativo suportar)
  // geom        Unsupported("geometry(Point, 4326)")?

  // Voltagem — para itens elétricos/eletrônicos
  voltage String? // "110V" | "220V" | "Bivolt" — null = não se aplica

  // Requisitos para reserva
  requireIdVerification Boolean @default(false) // locatário precisa ter identidade verificada
  requirePhone          Boolean @default(false) // locatário precisa ter telefone cadastrado

  // Status — fonte de verdade única para visibilidade e soft-delete
  // DRAFT: sem fotos; AVAILABLE: publicado; PAUSED: pausado pelo dono; DELETED: soft-delete
  status       ItemStatus @default(DRAFT)
  isApproved   Boolean    @default(true) // true = publicação direta (moderação reativa no MVP)
  approvedAt   DateTime?
  approvedById String?

  viewCount Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relações
  images    ItemImage[]
  bookings  Booking[]
  reviews   Review[]
  favorites Favorite[]

  @@index([ownerId])
  @@index([categoryId])
  @@index([latitude, longitude])
  @@index([status, isApproved, deletedAt])
  @@index([slug])
  @@map("items")
}

model ItemImage {
  id        String   @id @default(cuid())
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([itemId])
  @@map("item_images")
}

model Booking {
  id         String @id @default(cuid())
  itemId     String
  item       Item   @relation(fields: [itemId], references: [id])
  borrowerId String
  borrower   User   @relation("BorrowerBookings", fields: [borrowerId], references: [id])
  ownerId    String
  owner      User   @relation("OwnerBookings", fields: [ownerId], references: [id])

  status BookingStatus @default(PENDING)

  startDate DateTime
  endDate   DateTime
  totalDays Int

  // Snapshot de preço no momento da solicitação (protege contra mudança de preço)
  dailyPrice    Int
  totalPrice    Int
  depositAmount Int?

  borrowerNote String? @db.Text
  ownerNote    String? @db.Text

  // Pagamento via Stripe
  paymentStatus         PaymentStatus @default(PENDING)
  stripeSessionId       String?       @unique // Stripe Checkout Session ID
  stripePaymentIntentId String?
  paidAt                DateTime?

  cancelledAt   DateTime?
  cancelledById String?
  cancelReason  String?

  // Política de cancelamento — calculado no momento do cancelamento
  refundAmount  Int? // valor a reembolsar em centavos (null = não cancelado)
  refundPercent Int? // 100 | 70 | 50 — percentual aplicado pela política

  // Resposta do proprietário (para cálculo do badge de responsividade)
  respondedAt DateTime? // quando o dono aceitou ou recusou (primeira ação sobre PENDING)

  // Retirada real — gravada no mark_active; endDate é recalculado a partir daqui
  activatedAt DateTime? // horário real de retirada confirmada pelo locador

  // Token de segurança para retirada — gerado no pagamento, validado pelo proprietário na entrega
  pickupToken       String?   @unique // código de 6 dígitos exibido ao locatário
  pickupTokenUsedAt DateTime? // quando foi validado (mark_active)

  // Devolução e taxa de atraso
  returnedAt    DateTime? // data real de devolução (pode ser após endDate)
  lateFeeAmount Int? // cents — calculado se returnedAt > endDate

  // Contrato digital
  contractSignedAt DateTime?

  // P1-27 — Extensão de prazo
  extensionRequestedEndDate DateTime? // nova data de devolução solicitada pelo locatário
  extensionStatus           String? // "PENDING" | "APPROVED" | "REJECTED"
  extensionRequestedAt      DateTime? // quando a solicitação foi feita
  extensionRespondedAt      DateTime? // quando o proprietário respondeu

  // Financeiro — FIN-1.1
  platformFeeRate      Int?
  platformFeeAmount    Int?
  ownerNetAmount       Int?
  stripeFee            Int?
  depositStatus        DepositStatus @default(NONE)
  stripeDisputeId      String?

  // P3-20 — desconto de cupom aplicado na criação (absorvido pela taxa da plataforma, não pelo proprietário)
  discountCents Int?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // soft delete — LGPD obrigatório em dados transacionais

  // Relações
  reviews               Review[]
  conversation          Conversation?
  photos                BookingPhoto[]
  contractAcceptance    ContractAcceptance?
  platformTransactions  PlatformTransaction[]
  payouts               Payout[]
  ambassadorCommissions AmbassadorCommission[]
  couponUsed            Coupon?                @relation("CouponUsedInBooking")

  @@index([borrowerId])
  @@index([ownerId])
  @@index([itemId])
  @@index([status])
  @@index([deletedAt])
  @@index([itemId, status, startDate, endDate])
  @@index([ownerId, paymentStatus, paidAt])
  @@map("bookings")
}

// P3-20 — cupom de desconto ganho ao avaliar (1 por reserva avaliada por usuário).
// O desconto é absorvido pela taxa da plataforma; o proprietário recebe o valor cheio.
model Coupon {
  id         String  @id @default(cuid())
  userId     String
  user       User    @relation(fields: [userId], references: [id])
  code       String  @unique
  percentOff Int // ex.: 10 = 10%
  source     String  @default("review_reward")

  // Reserva que originou o cupom (impede cupom duplicado pela mesma reserva)
  sourceBookingId String?

  expiresAt DateTime
  usedAt    DateTime?
  // Reserva onde o cupom foi usado
  bookingId String?  @unique
  booking   Booking? @relation("CouponUsedInBooking", fields: [bookingId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, sourceBookingId])
  @@index([userId, usedAt])
  @@map("coupons")
}

model Review {
  id         String  @id @default(cuid())
  bookingId  String
  booking    Booking @relation(fields: [bookingId], references: [id])
  reviewerId String
  reviewer   User    @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  revieweeId String
  reviewee   User    @relation("ReviewsReceived", fields: [revieweeId], references: [id])
  itemId     String?
  item       Item?   @relation(fields: [itemId], references: [id])

  reviewType ReviewType
  rating     Int     // 1–5 overall
  comment    String? @db.Text

  // P3-68: emoji de satisfação (😠1 😕2 😐3 😊4 😍5)
  sentiment       Int?
  // P3-67: critérios por tipo de avaliação
  itemAsDescribed Int? // ITEM: item como descrito
  punctuality     Int? // OWNER/BORROWER: pontualidade
  communication   Int? // OWNER/BORROWER: comunicação
  conservation    Int? // ITEM/BORROWER: conservação/cuidado
  // P3-69: foto do item em uso
  photoUrl        String?

  createdAt DateTime @default(now())

  // Um revisor só avalia uma vez por booking por tipo
  @@unique([bookingId, reviewerId, reviewType])
  @@index([revieweeId])
  @@index([itemId])
  @@map("reviews")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, itemId])
  @@map("favorites")
}

model Conversation {
  id            String    @id @default(cuid())
  bookingId     String?   @unique
  booking       Booking?  @relation(fields: [bookingId], references: [id])
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())

  messages     Message[]
  participants ConversationParticipant[]

  @@map("conversations")
}

model ConversationParticipant {
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  lastReadAt     DateTime?

  @@id([conversationId, userId])
  @@index([userId])
  @@map("conversation_participants")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id])
  content        String       @db.Text
  readAt         DateTime?
  createdAt      DateTime     @default(now())
  deletedAt      DateTime? // soft delete — LGPD obrigatório em mensagens privadas

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("messages")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  data      Json? // dados extras (ex.: bookingId, itemId)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt])
  @@map("notifications")
}

// ─── NextAuth.js — requerido pelo @auth/prisma-adapter ───────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────────────────────────────────────

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@map("password_reset_tokens")
}

// ─────────────────────────────────────────────────────────────────────────────

// Webhooks de saída para integração PJ com ERPs e sistemas externos
model OutboundWebhook {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  url      String // endpoint que receberá os eventos
  events   String[] // ex.: ["booking.confirmed", "booking.paid"]
  secret   String // HMAC-SHA256 secret (mostrado apenas no momento da criação)
  isActive Boolean  @default(true)

  // Auditoria das últimas entregas
  lastFiredAt    DateTime?
  lastStatusCode Int?
  failureCount   Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("outbound_webhooks")
}

// ─────────────────────────────────────────────────────────────────────────────

// Model ReferralCredit removido (ADR-022 — substituído por programa de embaixadores).
// Tabela "referral_credits" é dropada na migration add-ambassador-program.sql.

model AdminLog {
  id         String   @id @default(cuid())
  adminId    String
  admin      User     @relation(fields: [adminId], references: [id])
  action     String // ex.: "APPROVE_ITEM", "BAN_USER", "RESOLVE_DISPUTE"
  entityType String // ex.: "Item", "User", "Booking"
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([adminId])
  @@index([entityType, entityId])
  @@map("admin_logs")
}

// ─── Fotos de check-in / check-out ───────────────────────────────────────────

model BookingPhoto {
  id         String     @id @default(cuid())
  bookingId  String
  booking    Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  url        String
  phase      CheckPhase // CHECKIN | CHECKOUT
  uploadedBy String // userId de quem fez o upload

  createdAt DateTime @default(now())

  @@index([bookingId])
  @@map("booking_photos")
}

// ─── Contrato digital ─────────────────────────────────────────────────────────

model ContractAcceptance {
  id        String  @id @default(cuid())
  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  acceptedAt DateTime @default(now())
  ipAddress  String?
  userAgent  String?

  @@map("contract_acceptances")
}

// ─── Módulo Financeiro — FIN-1.1 ─────────────────────────────────────────────

model OwnerPaymentAccount {
  id          String           @id @default(cuid())
  userId      String           @unique
  user        User             @relation(fields: [userId], references: [id])
  pixKeyType  PixKeyType
  pixKey      String
  holderName  String
  bankName    String?
  status      PixAccountStatus @default(PENDING_VERIFICATION)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  payouts     Payout[]

  @@map("owner_payment_accounts")
}

model PlatformTransaction {
  id          String          @id @default(cuid())
  bookingId   String
  booking     Booking         @relation(fields: [bookingId], references: [id])
  type        TransactionType
  amount      Int
  description String?
  metadata    Json?
  createdAt   DateTime        @default(now())

  @@index([bookingId])
  @@map("platform_transactions")
}

model Payout {
  id                    String              @id @default(cuid())
  ownerPaymentAccountId String
  ownerPaymentAccount   OwnerPaymentAccount @relation(fields: [ownerPaymentAccountId], references: [id])
  bookingId             String
  booking               Booking             @relation(fields: [bookingId], references: [id])
  amount                Int
  status                PayoutStatus        @default(PENDING)
  eligibleAfter         DateTime
  processedAt           DateTime?
  failureReason         String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@index([eligibleAfter, status])
  @@index([ownerPaymentAccountId, status])
  @@map("payouts")
}

model PlatformConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedBy   String?
  updatedAt   DateTime @updatedAt

  @@map("platform_configs")
}

model ExportJob {
  id          String          @id @default(cuid())
  requestedBy String
  admin       User            @relation(fields: [requestedBy], references: [id])
  periodStart DateTime
  periodEnd   DateTime
  status      ExportJobStatus @default(PENDING)
  fileUrl     String?         // URL assinada do Supabase Storage (validade 48h)
  errorMessage String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([requestedBy, createdAt])
  @@index([status])
  @@map("export_jobs")
}

model StripeEventQueue {
  id            String           @id @default(cuid())
  stripeEventId String           @unique
  type          String
  payload       Json
  status        EventQueueStatus @default(PENDING)
  attempts      Int              @default(0)
  lastError     String?
  processedAt   DateTime?
  createdAt     DateTime         @default(now())

  @@index([status, createdAt])
  @@map("stripe_event_queue")
}

// ─── Programa Fundadores ──────────────────────────────────

model FounderLead {
  id            String      @id @default(cuid())
  email         String      @unique
  name          String?
  intent        String      @default("proprietario") // "proprietario" | "locatario"
  queuePosition Int         @unique @default(autoincrement())
  wave          FounderWave @default(WAVE_1)          // atualizado pela API após create
  status        LeadStatus  @default(PENDING)
  source        SignupSource @default(VIP_LANDING)

  // LGPD — consentimento explícito (LGPD Art. 7 + ANPD)
  marketingConsentAt DateTime
  consentVersion     String   @default("v1.0")
  consentIp          String?
  consentUserAgent   String?  @db.VarChar(500)

  // Conversão: preenchido quando lead cria conta via link de convite
  convertedUserId String?  @unique
  convertedUser   User?    @relation(fields: [convertedUserId], references: [id])
  invitedAt       DateTime?
  convertedAt     DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([status])
  @@index([createdAt])
  @@map("founder_leads")
}

model FounderBenefit {
  id          String      @id @default(cuid())
  wave        FounderWave
  key         String      // "feeRate" | "searchBoost" | "freeVerification"
  value       String      // string-encoded (basis points, float, "true"/"false")
  description String?
  active      Boolean     @default(true)
  effectiveFrom  DateTime @default(now())
  effectiveUntil DateTime?
  createdAt      DateTime @default(now())

  @@unique([wave, key])
  @@map("founder_benefits")
}

model FounderAuditLog {
  id        String   @id @default(cuid())
  leadId    String?
  userId    String?
  action    String   // "LEAD_CREATED" | "INVITED" | "CONVERTED" | "UNSUBSCRIBED"
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([userId])
  @@map("founder_audit_logs")
}

// ─── Programa de Embaixadores (ADR-022) ──────────────────────────

/// Vínculo 1:1 com User. Criado no opt-in do programa.
/// Mantém estado denormalizado (tier vigente, totais acumulados) para leitura O(1) no painel.
/// Tier vigente é atualizado pelo webhook que cria AmbassadorCommission — não há cron noturno
/// para tier; apenas para EXPIRED em Referral.
model AmbassadorProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Tier vigente — recalculado a cada nova ACTIVE/EXPIRED em Referral.
  // Fonte da verdade é a contagem em Referral; este campo é cache.
  currentTier        AmbassadorTier @default(BRONZE)
  activeReferralsCnt Int            @default(0) // denormalizado — usado para badge no painel

  // Totais acumulados em centavos (denormalizados para dashboard).
  // Recalculáveis a partir de AmbassadorCommission — campos são cache.
  totalCommissionPendingCents  Int @default(0) // soma de PENDING + APPROVED ainda não pagas
  totalCommissionPaidCents     Int @default(0) // soma de PAID (zero no MVP até D4)
  totalCommissionCancelledCents Int @default(0) // soma de CANCELLED — métrica de qualidade

  // Conta de payout — preenchido quando D4 destravar
  pixKey                  String?
  pixKeyType              PixKeyType?
  stripeConnectAccountId  String?     // reservado para evolução pós-dez/2026

  // LGPD — opt-in auditável
  consentAt        DateTime
  consentVersion   String   @default("v1.0")
  consentIp        String?
  consentUserAgent String?  @db.VarChar(500)
  revokedAt        DateTime? // null = ativo; preencher encerra atribuição futura

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  commissions AmbassadorCommission[]

  @@index([currentTier])
  @@map("ambassador_profiles")
}

/// Aresta do grafo de indicações (referrer → referred).
/// Único por par — bloqueia duplicação. Persiste após EXPIRED para auditoria.
/// Status PENDING vira ACTIVE no primeiro booking pago do indicado; EXPIRED após 12 meses sem atividade.
model Referral {
  id           String         @id @default(cuid())
  referrerId   String
  referrer     User           @relation("ReferralsAsReferrer", fields: [referrerId], references: [id])
  referredId   String         @unique // 1:1 — um usuário só pode ter sido indicado uma vez
  referred     User           @relation("ReferralAsReferred", fields: [referredId], references: [id])
  status       ReferralStatus @default(PENDING)
  activatedAt  DateTime?      // preenchido quando vira ACTIVE
  expiredAt    DateTime?      // preenchido quando vira EXPIRED
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  commissions AmbassadorCommission[]

  @@unique([referrerId, referredId])
  @@index([referrerId, status])
  @@index([status, activatedAt])
  @@map("referrals")
}

/// Snapshot imutável de cada comissão gerada por uma reserva paga.
/// Vinculada a Booking (FK), Referral (FK) e AmbassadorProfile (FK).
/// Tier e taxa são capturados no momento da criação — auditoria garantida mesmo após
/// embaixador subir/descer de tier ou taxa da plataforma mudar.
model AmbassadorCommission {
  id                  String           @id @default(cuid())
  ambassadorProfileId String
  ambassadorProfile   AmbassadorProfile @relation(fields: [ambassadorProfileId], references: [id])
  ambassadorUserId    String           // denormalizado para joins rápidos
  ambassadorUser      User             @relation("AmbassadorCommissions", fields: [ambassadorUserId], references: [id])
  referralId          String
  referral            Referral         @relation(fields: [referralId], references: [id])
  bookingId           String
  booking             Booking          @relation(fields: [bookingId], references: [id])

  // Snapshot — imutável após criação
  tierSnapshot        AmbassadorTier   // tier vigente no momento da geração
  tierPercentBp       Int              // 300 | 500 | 700
  platformFeeAmount   Int              // centavos — capturado do Booking
  amountCents         Int              // platformFeeAmount * tierPercentBp / 10000

  status              CommissionStatus @default(PENDING)
  approvedAt          DateTime?        // marcado pelo cron T+7 após Booking COMPLETED
  paidAt              DateTime?        // bloqueado até D4 — sempre null no MVP
  cancelledAt         DateTime?
  cancelReason        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([bookingId, referralId]) // uma comissão por par booking+referral — idempotência do webhook
  @@index([ambassadorProfileId, status])
  @@index([status, approvedAt])
  @@index([bookingId])
  @@map("ambassador_commissions")
}
