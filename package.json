    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-query-devtools": "^5.62.0",
    "zod": "^3.23.8",
    "@supabase/supabase-js": "^2.46.0",
    "@supabase/ssr": "^0.4.0",
    "bcryptjs": "^2.4.3",
    "jose": "^5.9.0",
    "resend": "^4.0.0",
