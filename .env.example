# ShareO — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# NUNCA commite o .env.local ou qualquer arquivo com valores reais

# ─── Banco de Dados (Supabase) ───────────────────────────
# Connection string com pooler (para queries da app)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (para Prisma migrations — bypass do pooler)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

# ─── Supabase (cliente JS) ───────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."  # Apenas server-side — nunca expor no client

# ─── Autenticação (NextAuth.js v5) ───────────────────────
# Gerar com: openssl rand -base64 32
AUTH_SECRET="seu-secret-de-32-bytes-aqui"
AUTH_URL="http://localhost:3000"  # Em produção: https://www.shareo.com.br

# Providers OAuth (opcionais no MVP — descomente se usar)
# AUTH_GOOGLE_ID="..."
# AUTH_GOOGLE_SECRET="..."

# ─── Criptografia de Dados Sensíveis (CPF/CNPJ) ─────────
# Gerar com: openssl rand -hex 32
# Algoritmo: AES-256-GCM (ver ADR-004 quando criado)
ENCRYPTION_KEY="sua-chave-de-32-bytes-hex-aqui"
ENCRYPTION_IV_LENGTH="12"  # bytes para GCM

# ─── API de Mapas ────────────────────────────────────────
# Ver ADR-002 para a decisão Mapbox vs Google Maps
NEXT_PUBLIC_MAPBOX_TOKEN="pk.eyJ..."
# ou:
# NEXT_PUBLIC_GOOGLE_MAPS_KEY="AIza..."

# ─── Storage de Imagens (Supabase Storage) ───────────────
NEXT_PUBLIC_STORAGE_BUCKET="item-images"
STORAGE_MAX_FILE_SIZE_MB="5"

# ─── Validação de CPF/CNPJ ───────────────────────────────
# No MVP: validação local (dígito verificador) — sem serviço externo
# Descomente na H2 se integrar com Receita Federal
# CPF_CNPJ_API_KEY="..."
# CPF_CNPJ_API_URL="..."

# ─── Monitoramento / Erros ───────────────────────────────
NEXT_PUBLIC_SENTRY_DSN="https://...@sentry.io/..."
SENTRY_AUTH_TOKEN="..."  # Para upload de source maps no CI
SENTRY_ORG="shareo"
SENTRY_PROJECT="shareo-web"

# ─── App ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="ShareO"

# Cidade padrão para geo-search inicial (Natal/RN)
NEXT_PUBLIC_DEFAULT_CITY="Natal"
NEXT_PUBLIC_DEFAULT_STATE="RN"
NEXT_PUBLIC_DEFAULT_LAT="-5.7945"
NEXT_PUBLIC_DEFAULT_LNG="-35.2110"
NEXT_PUBLIC_DEFAULT_RADIUS_KM="10"

# ─── E-mail (transacional) ───────────────────────────────
# Para confirmação de cadastro, notificações
# Opções: Resend, SendGrid, AWS SES
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@shareo.com.br"

# ─── Feature Flags (desenvolvimento) ────────────────────
# true/false — controla features em desenvolvimento
NEXT_PUBLIC_FEATURE_CHAT_ENABLED="true"
NEXT_PUBLIC_FEATURE_REVIEWS_ENABLED="true"
NEXT_PUBLIC_FEATURE_ADMIN_ENABLED="true"

# ─── Ambiente ───────────────────────────────────────────
NODE_ENV="development"  # development | staging | production
