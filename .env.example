# ShareO — Variáveis de Ambiente
# ─────────────────────────────────────────────────────────────────────────────
# INSTRUÇÕES:
#   - Development (local): copie para .env.local e preencha
#   - Staging/Production: configure diretamente no GitHub Secrets e no Vercel
#   - NUNCA commite .env.local, .env.staging ou .env.production com valores reais
#   - Cada ambiente tem seu próprio projeto Supabase — sem compartilhamento de dados
#
# AMBIENTES:
#   development  → banco Supabase "shareo-dev" (projeto isolado)
#   staging      → banco Supabase "shareo-staging" (espelho da produção)
#   production   → banco Supabase "shareo-prod" (dados reais)
# ─────────────────────────────────────────────────────────────────────────────

# ─── Banco de Dados (Supabase) ───────────────────────────────────────────────
# Connection string com pooler (para queries da app via Prisma)
# DEV:     postgresql://postgres.[dev-ref]:[password]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# STAGING: postgresql://postgres.[staging-ref]:[password]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# PROD:    postgresql://postgres.[prod-ref]:[password]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (para Prisma migrations — bypass do pooler)
# Usar a porta 5432, sem ?pgbouncer=true
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

# ─── Supabase (cliente JS) ───────────────────────────────────────────────────
# Encontre em: Supabase Dashboard > Settings > API > Project URL / Anon Key
#
# DEV:     https://[dev-ref].supabase.co
# STAGING: https://[staging-ref].supabase.co     (GitHub Secret: NEXT_PUBLIC_SUPABASE_URL_STAGING)
# PROD:    https://[prod-ref].supabase.co         (GitHub Secret: NEXT_PUBLIC_SUPABASE_URL_PROD)
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"

# Anon key — segura para expor no client (respeita RLS)
# DEV:     eyJ... (dev project anon key)
# STAGING: GitHub Secret: NEXT_PUBLIC_SUPABASE_ANON_KEY_STAGING
# PROD:    GitHub Secret: NEXT_PUBLIC_SUPABASE_ANON_KEY_PROD
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# Service Role key — APENAS server-side — nunca expor no client ou logs
# Encontre em: Supabase Dashboard > Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ─── Autenticação (NextAuth.js v5) ───────────────────────────────────────────
# Gerar com: openssl rand -base64 32
# MESMO secret em todos os ambientes NÃO é recomendado — use valores distintos
# GitHub Secret: AUTH_SECRET (um por ambiente ou compartilhado conforme política)
AUTH_SECRET="seu-secret-de-32-bytes-aqui"

# URL base da aplicação — usada pelo NextAuth para callbacks OAuth
# DEV:     http://localhost:3000
# STAGING: https://staging.shareo.com.br   (ou URL gerada pelo Vercel)
# PROD:    https://www.shareo.com.br
AUTH_URL="http://localhost:3000"

# Providers OAuth (opcionais no MVP — descomente se usar)
# AUTH_GOOGLE_ID="..."
# AUTH_GOOGLE_SECRET="..."

# ─── Criptografia de Dados Sensíveis (CPF/CNPJ) ─────────────────────────────
# Gerar com: openssl rand -hex 32
# Algoritmo: AES-256-GCM (ver ADR-005-criptografia-documentos.md)
# OBRIGATÓRIO ser diferente por ambiente para isolamento de dados
# GitHub Secret: ENCRYPTION_KEY
ENCRYPTION_KEY="sua-chave-de-32-bytes-hex-aqui"
ENCRYPTION_IV_LENGTH="12"  # bytes para GCM — não alterar

# ─── API de Mapas (Mapbox) ───────────────────────────────────────────────────
# Ver ADR-002-mapas.md — decisão: Mapbox + PostGIS
# Criar token em: https://account.mapbox.com/access-tokens/
# Restringir token de produção por URL de referência no painel Mapbox
# GitHub Secret (opcional): NEXT_PUBLIC_MAPBOX_TOKEN
NEXT_PUBLIC_MAPBOX_TOKEN="pk.eyJ..."

# ─── Storage de Imagens (Supabase Storage) ───────────────────────────────────
# Bucket criado via script scripts/apply-rls.ts (pnpm rls)
# Ver ADR-010-upload-imagens.md
NEXT_PUBLIC_STORAGE_BUCKET="item-images"
STORAGE_MAX_FILE_SIZE_MB="5"

# ─── Monitoramento / Erros (Sentry) ─────────────────────────────────────────
# Criar projeto em: https://sentry.io/organizations/shareo/projects/
# SENTRY_AUTH_TOKEN: Settings > API Keys — necessário para upload de source maps no CI
# Filtros de PII configurados no sentry.server.config.ts (CPF, e-mail não aparecem nos logs)
NEXT_PUBLIC_SENTRY_DSN="https://...@sentry.io/..."
SENTRY_AUTH_TOKEN="..."
SENTRY_ORG="shareo"
SENTRY_PROJECT="shareo-web"

# ─── App ─────────────────────────────────────────────────────────────────────
# DEV:     http://localhost:3000
# STAGING: https://staging.shareo.com.br   (GitHub Secret: STAGING_URL)
# PROD:    https://www.shareo.com.br
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="ShareO"

# Cidade padrão para geo-search inicial (Natal/RN)
NEXT_PUBLIC_DEFAULT_CITY="Natal"
NEXT_PUBLIC_DEFAULT_STATE="RN"
NEXT_PUBLIC_DEFAULT_LAT="-5.7945"
NEXT_PUBLIC_DEFAULT_LNG="-35.2110"
NEXT_PUBLIC_DEFAULT_RADIUS_KM="10"

# ─── E-mail transacional (Resend) ────────────────────────────────────────────
# Criar API key em: https://resend.com/api-keys
# DEV: use o domínio sandbox do Resend (onboarding@resend.dev como remetente)
# PROD: requer domínio verificado shareo.com.br
# GitHub Secret: RESEND_API_KEY
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@shareo.com.br"

# ─── Pagamentos (Stripe) ─────────────────────────────────────────────────────
# DEV/STAGING: chaves test (sk_test_..., pk_test_...)
# PROD:        chaves live (sk_live_..., pk_live_...)
# Painel: https://dashboard.stripe.com/apikeys
# GitHub Secrets: STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET
STRIPE_SECRET_KEY="sk_test_..."
# Webhook secret — gerado em Stripe Dashboard > Webhooks
# Endpoint prod: https://www.shareo.com.br/api/webhooks/stripe
# Eventos obrigatórios: checkout.session.completed, checkout.session.expired, charge.refunded
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── Validação de CPF/CNPJ ───────────────────────────────────────────────────
# MVP: validação local (dígito verificador) — sem serviço externo
# H2: descomente se integrar com Receita Federal
# CPF_CNPJ_API_KEY="..."
# CPF_CNPJ_API_URL="..."

# ─── Feature Flags ───────────────────────────────────────────────────────────
# Controla features em desenvolvimento — true/false
NEXT_PUBLIC_FEATURE_CHAT_ENABLED="true"
NEXT_PUBLIC_FEATURE_REVIEWS_ENABLED="true"
NEXT_PUBLIC_FEATURE_ADMIN_ENABLED="true"

# ─── Ambiente ────────────────────────────────────────────────────────────────
NODE_ENV="development"  # development | staging | production

# ─────────────────────────────────────────────────────────────────────────────
# RESUMO DE GITHUB SECRETS NECESSÁRIOS (configurar em Settings > Secrets > Actions)
# ─────────────────────────────────────────────────────────────────────────────
#
# Vercel (todos os ambientes):
#   VERCEL_TOKEN
#   VERCEL_ORG_ID
#   VERCEL_PROJECT_ID
#
# Supabase — Staging:
#   NEXT_PUBLIC_SUPABASE_URL_STAGING
#   NEXT_PUBLIC_SUPABASE_ANON_KEY_STAGING
#   DATABASE_URL_STAGING
#   DIRECT_URL_STAGING
#
# Supabase — Production:
#   NEXT_PUBLIC_SUPABASE_URL_PROD
#   NEXT_PUBLIC_SUPABASE_ANON_KEY_PROD
#   DATABASE_URL_PROD
#   DIRECT_URL_PROD
#
# Autenticação / Criptografia:
#   AUTH_SECRET
#   ENCRYPTION_KEY
#
# URLs:
#   STAGING_URL            (ex: https://staging.shareo.com.br)
#
# Opcional (Lighthouse CI):
#   LHCI_GITHUB_APP_TOKEN
# ─────────────────────────────────────────────────────────────────────────────
